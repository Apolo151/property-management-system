# Copy to `.env` at repository root for docker compose variable substitution.
# Do not commit real secrets.

# Merge base compose + dev bind mounts (hot reload). For prod-like runs use explicit:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# API (published to host)
PORT=8000
NODE_ENV=development

# Frontend (Vite dev)
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000/api

# Production merge (docker-compose.prod.yml): public hostname and SPA → API URL
PUBLIC_APP_DOMAIN=localhost
CADDY_EMAIL=you@example.com
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
# Used when building the production frontend image (defaults use PUBLIC_APP_DOMAIN)
VITE_PROD_API_URL=https://${PUBLIC_APP_DOMAIN}/api

# PostgreSQL (DB_PORT = port inside compose network; HOST_DB_PORT = published host port)
DB_HOST=postgres
DB_PORT=5432
HOST_DB_PORT=5432
DB_NAME=hotel_pms_dev
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# API CORS in production (passed through to backend when NODE_ENV=production)
# CORS_ORIGIN=https://${PUBLIC_APP_DOMAIN}
# CORS_ORIGINS=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Sync / integrations
SYNC_INTERVAL_MS=60000
SYNC_ENABLED=true
QLOAPPS_DEFAULT_CURRENCY=EGP
QLOAPPS_SYNC_INTERVAL_MS=300000
QLO_API_URL=
QLO_API_KEY=
ENCRYPTION_KEY=

# Optional QloApps container (profile: infra)
QLOAPPS_PORT=8080
QLOAPPS_USER_PASSWORD=qloappsuserpassword
QLOAPPS_MYSQL_ROOT_PASSWORD=myrootpassword
QLOAPPS_MYSQL_DATABASE=qlo170

# Beds24 (optional)
BEDS24_API_KEY=
BEDS24_PROP_KEY=
BEDS24_API_URL=https://api.beds24.com/v2
BEDS24_WEBHOOK_SECRET=
