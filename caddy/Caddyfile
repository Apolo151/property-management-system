# Used by root docker-compose.prod.yml merge (static SPA + API).
# Set PUBLIC_APP_DOMAIN in the environment (e.g. .env). Caddy obtains TLS certs automatically for public hostnames.
# Frontend static files are served from a volume mounted at /frontend (built by frontend-builder service).

{
	email {$CADDY_EMAIL}
}

{$PUBLIC_APP_DOMAIN} {
	encode gzip

	# API is mounted under /api on the Express app
	handle /api* {
		reverse_proxy api:8000
	}

	# Static SPA application running in the frontend container
	handle {
		reverse_proxy frontend:80
	}
}
