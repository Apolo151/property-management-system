# Used by root docker-compose.prod.yml merge (SPA + API).
# Set PUBLIC_APP_DOMAIN in the environment (e.g. .env). Caddy obtains TLS certs automatically for public hostnames.

{
	email {$CADDY_EMAIL}
}

{$PUBLIC_APP_DOMAIN} {
	encode gzip

	# API is mounted under /api on the Express app
	handle /api* {
		reverse_proxy api:8000
	}

	# Static SPA (nginx stage in frontend image)
	handle {
		reverse_proxy frontend:80
	}
}
