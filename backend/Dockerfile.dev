FROM node:24-alpine

WORKDIR /app

# Install dependencies for hot reload
COPY package*.json ./
RUN npm ci

# Copy source code
COPY . .

EXPOSE 8000

# Use the custom entrypoint to handle DB initialization
COPY docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

ENTRYPOINT ["docker-entrypoint.sh"]
CMD ["npm", "run", "dev"]
