# Server Configuration
NODE_ENV=development
PORT=3000

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotel_pms_dev
DB_NAME_TEST=hotel_pms_test
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Legacy DATABASE_URL (optional, for backward compatibility)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hotel_pms_dev

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS (production): set one of these instead of relying on permissive dev behavior
# CORS_ORIGIN=https://your-frontend.example.com
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Password reset (UC-004): link prefix for emails / logs (see auth_notifier)
# PASSWORD_RESET_PUBLIC_URL=https://your-frontend.example.com
# PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# Optional SMTP (not wired in code yet — reset link is logged when unset)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Beds24 Channel Manager Integration
BEDS24_API_KEY=your_beds24_api_key
BEDS24_PROP_KEY=your_beds24_property_key
BEDS24_API_URL=https://api.beds24.com/v2
BEDS24_WEBHOOK_SECRET=your_webhook_secret